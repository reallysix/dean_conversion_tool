# Copy this file to Scripts/release_config.env and fill in your Apple Developer values.
# Keep the real file local; it contains release signing configuration.

# Reverse-DNS bundle identifier registered in Apple Developer.
export APP_BUNDLE_ID="com.yourcompany.deanconversiontool"

# Apple Developer Team ID, for example ABCDE12345.
export APPLE_TEAM_ID="YOUR_TEAM_ID"

# Exact Developer ID Application certificate name from Keychain Access.
export DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (YOUR_TEAM_ID)"

# Keychain profile created with:
# xcrun notarytool store-credentials dean-conversion-tool
export NOTARYTOOL_PROFILE="dean-conversion-tool"
